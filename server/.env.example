PORT=5000
SUPABASE_URL=https://your-new-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Redis Configuration (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Provider Keys
RESEND_API_KEY=re_xxx
ZEPTOMAIL_API_KEY=your_zeptomail_api_key
ZEPTOMAIL_OAUTH_TOKEN=your_short_lived_zeptomail_oauth_access_token
ZEPTOMAIL_REFRESH_TOKEN=your_zeptomail_oauth_refresh_token
ZOHO_CLIENT_ID=your_zoho_self_client_id
ZOHO_CLIENT_SECRET=your_zoho_self_client_secret
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZEPTOMAIL_MAIL_AGENT_KEY=your_zeptomail_agent_alias
ZEPTOMAIL_BOUNCE_ADDRESS=bounce@yourdomain.com
ZEPTOMAIL_FROM_EMAIL=onboarding@yourdomain.com

# Service Security
# Dashboard uses this key in headers to perform admin actions (e.g. template edits, manual sends)
ADMIN_API_KEY=your-custom-supermailbox-admin-secret-key
